# ============================================================
# Variables de entorno de A Tu Paso
# ------------------------------------------------------------
# CÓMO USAR ESTE ARCHIVO
#   1. Copia este archivo y renómbralo a ".env.local" (en local)
#      o añade estas variables en Vercel (Settings → Environment
#      Variables) para producción.
#   2. Rellena los valores. NUNCA subas ".env.local" al repositorio:
#      ya está excluido en .gitignore.
# ============================================================

# ------------------------------------------------------------
# Clave secreta de Stripe
# ------------------------------------------------------------
# Dónde obtenerla:
#   1. Entra en https://dashboard.stripe.com
#   2. Menú "Desarrolladores" → "Claves de API"
#   3. Copia la "Clave secreta".
#      - Para probar: la de modo TEST (empieza por sk_test_...)
#      - Para cobrar de verdad: la de modo PRODUCCIÓN (sk_live_...)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx

# ------------------------------------------------------------
# ID del precio de la suscripción (6,95 €/mes)
# ------------------------------------------------------------
# Dónde obtenerlo:
#   1. En el panel de Stripe: "Catálogo de productos" → "+ Añadir producto"
#   2. Nombre: "A Tu Paso" · Precio: 6,95 EUR · Facturación: "Recurrente",
#      periodicidad "Mensual". Guarda el producto.
#   3. Abre el producto, y en la sección de precios copia el
#      identificador del precio (empieza por price_...).
# Ojo: el precio de modo TEST y el de modo PRODUCCIÓN tienen IDs
# distintos; usa el que corresponda a tu clave.
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
